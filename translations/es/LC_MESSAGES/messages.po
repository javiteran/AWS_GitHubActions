# --- Mensajes de éxito dinámicos ---
msgid "Student Added Successfully! 🎉"
msgstr "¡Estudiante Añadido Correctamente! 🎉"

msgid "Student %(name)s %(surname)s has been added to class %(nameclass)s with note %(note)s."
